{
  "name": "my-ai-stack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "@orpc/tanstack-query": "^1.13.6",
      "better-auth": "1.5.2",
      "@polar-sh/better-auth": "^1.6.4",
      "ai": "^6.0.3",
      "alchemy": "^0.87.0",
      "@better-auth/expo": "1.5.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:desktop": "turbo -F desktop dev:hmr",
    "build:desktop": "turbo -F desktop build:stable",
    "build:desktop:canary": "turbo -F desktop build:canary",
    "dev:tui": "turbo -F tui dev",
    "db:push": "turbo -F @my-ai-stack/db db:push",
    "db:studio": "turbo -F @my-ai-stack/db db:studio",
    "db:generate": "turbo -F @my-ai-stack/db db:generate",
    "db:migrate": "turbo -F @my-ai-stack/db db:migrate",
    "db:start": "turbo -F @my-ai-stack/db db:start",
    "db:watch": "turbo -F @my-ai-stack/db db:watch",
    "db:stop": "turbo -F @my-ai-stack/db db:stop",
    "db:down": "turbo -F @my-ai-stack/db db:down",
    "deploy": "turbo -F @my-ai-stack/infra deploy",
    "destroy": "turbo -F @my-ai-stack/infra destroy",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^1.0.5",
    "@ai-sdk/openai": "^1.0.14",
    "@anthropic-ai/sdk": "^0.79.0",
    "@langchain/anthropic": "^1.3.24",
    "@langchain/core": "^1.1.33",
    "@my-ai-stack/env": "workspace:*",
    "ai": "^6.0.116",
    "dotenv": "catalog:",
    "langchain": "^1.2.33",
    "nanoid": "^5.0.7",
    "pgvector": "^0.2.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@my-ai-stack/config": "workspace:*",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^22.13.14",
    "husky": "latest",
    "lefthook": "latest",
    "lint-staged": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.3.1"
  },
  "overrides": {
    "@vue/devtools-api": "^8.0.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.10"
}
